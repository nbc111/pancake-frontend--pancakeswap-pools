# 生产服务器：把需要的行复制到 apps/web/.env（.env 已被 .gitignore，勿把密码提交到 Git）
#
# 1) 启动 PostgreSQL（二选一）
#
# A. 本机已装 Docker，在 apps/web 目录执行：
#    docker compose -f docker-compose.referral-pg.yml up -d
#    默认账号 referral / referral，库名 referral，宿主机端口 5433
#
# B. 使用自建 PostgreSQL：自行建库与用户，把下面 DATABASE_URL 改成你的连接串
#
# 2) 同步 RewardPaid / 返佣记账 必须配置 DATABASE_URL；仅文件模式不支持 POST …/sync-staking-reward-paid

DATABASE_URL=postgresql://referral:referral@127.0.0.1:5433/referral

# 服务端鉴权（可选）：与构建时 NEXT_PUBLIC_REFERRAL_ADMIN_SECRET 设为相同字符串，管理页 fetch 才会带上 Bearer
# REFERRAL_ADMIN_SECRET=
# NEXT_PUBLIC_REFERRAL_ADMIN_SECRET=

# 链上索引 RPC（可选，默认 https://rpc.nbcex.com）
# NBC_STAKING_INDEXER_RPC_URL=https://rpc.nbcex.com
